# =============================================================
# Variables d'environnement — Le Chat à 3 Têtes
# Copie ce fichier en .env.local et renseigne les valeurs.
# =============================================================

# URL publique de ton site (utilisée pour les redirects OAuth, og:image…)
# En local : http://localhost:3000
# En prod  : https://lechata3tetes.vercel.app (ou ton domaine)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (obligatoire) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key — UNIQUEMENT côté serveur. Ne jamais exposer.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Instagram (optionnel — uniquement quand l'app Meta est validée) ---
# Voir docs/META-INSTAGRAM-SETUP.md pour récupérer ces valeurs.
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Meta App OAuth (optionnel — pour rafraîchir le token plus tard) ---
META_APP_ID=
META_APP_SECRET=
